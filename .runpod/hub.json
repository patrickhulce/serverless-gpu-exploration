{
  "title": "LTX-2 serverless evaluation (bake variant)",
  "description": "Internal benchmark harness: 4 LTX-2 storage variants (bake/live/cache/volume) + a diagnostics endpoint for cold-start and GPU microbenchmarking on RunPod Serverless.",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 120,
    "gpuCount": 1,
    "gpuIds": "AMPERE_80",
    "allowedCudaVersions": [
      "12.8",
      "12.7",
      "12.6",
      "12.5",
      "12.4"
    ],
    "env": [
      {
        "key": "WORKER_ROLE",
        "input": {
          "name": "Worker role",
          "type": "string",
          "options": [
            {
              "label": "LTX-2",
              "value": "ltx2"
            }
          ],
          "default": "ltx2"
        }
      },
      {
        "key": "MODEL_SOURCE",
        "input": {
          "name": "Model source",
          "type": "string",
          "options": [
            {
              "label": "Bake",
              "value": "bake"
            }
          ],
          "default": "bake"
        }
      },
      {
        "key": "MODEL_PATH",
        "input": {
          "name": "Model path",
          "type": "string",
          "default": "/opt/models/ltx-2"
        }
      }
    ]
  }
}
